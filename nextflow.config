// Parameters
params {
    // Input options
    pod5_sheet       = null   // TSV file with sample_id, path columns
    reference_genome = null   // Reference genome FASTA file for alignment
    basecall_model   = null   // Dorado basecalling model
    dna              = false  // DNA sequencing mode (mutually exclusive with --cdna)
    cdna             = false  // cDNA sequencing mode (mutually exclusive with --dna)

    // Output options
    output_dir          = "output"
    publish_merged_bams = true  // Merged BAM files after basecalling
    publish_fastq       = true  // FASTQ files converted from BAMs
}

// Parameter validation
plugins {
    id 'nf-schema@2.3.0'
}

validation {
    help {
        enabled = true
        showHidden = false
    }
    parametersSchema = 'nextflow_schema.json'
    monochromeLogs = false
    failUnrecognisedParams = true
    lenientMode = false
}

// Container
process.container = 'oras://ghcr.io/shians/dorado-container:1.1.1-singularity'

// Resource tiers — assign to processes via the label directive
process {
    withLabel: tiny {
        cpus   = 2
        memory = '4.GB'
        time   = '2h'
    }
    withLabel: small {
        cpus   = 4
        memory = '16.GB'
        time   = '4h'
    }
    withLabel: medium {
        cpus   = 8
        memory = '32.GB'
        time   = '12h'
    }
    withLabel: large {
        cpus   = 24
        memory = '128.GB'
        time   = '24h'
    }
}

// Singularity
singularity {
    enabled    = true
    autoMounts = true
    runOptions = '--nv'  // Enable NVIDIA GPU support
}

// Reporting
timeline {
    enabled   = true
    file      = "logs/runtime_reports/main_timeline.html"
    overwrite = true
}

report {
    enabled   = true
    file      = "logs/runtime_reports/main_report.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "logs/runtime_reports/main_trace.txt"
    overwrite = true
}

// Profiles
// Usage: nextflow run main.nf -profile <profile_name>
//   singularity  — local execution with Singularity containers
//   slurm_gpu    — SLURM cluster with GPU support for basecalling
profiles {
    singularity {
        singularity {
            enabled    = true
            autoMounts = true
            runOptions = '--nv'
        }
        cleanup = false
    }

    gpu_slurm {
        singularity {
            enabled    = true
            autoMounts = true
            runOptions = '--nv'
        }
        process {
            executor = 'slurm'
        }
        cleanup = false
    }

    gpu_wehi {
        singularity {
            enabled    = true
            autoMounts = true
            runOptions = '--nv'
        }
        process {
            executor = 'slurm'
            withName: 'doradoBaseCall' {
                queue          = 'gpuq'
                clusterOptions = '--gres=gpu:A30:1'
            }
        }
        cleanup = false
    }
}
