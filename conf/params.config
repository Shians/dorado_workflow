// Pipeline parameters configuration
params {
  // Input options
  pod5_sheet = null                // TSV file with sample_id, path columns
  reference_genome = null
  basecall_model = null            // Dorado basecalling model

  // Output options
  output_dir = "output"
  publish_merged_bams = true       // Merged BAM files after basecalling
  publish_fastq = true             // FASTQ files converted from BAMs
}
