{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/shians/dorado-workflow/main/nextflow_schema.json",
    "title": "Dorado Workflow Parameters",
    "description": "Oxford Nanopore basecalling and alignment pipeline",
    "type": "object",
    "defs": {
        "input_options": {
            "title": "Input Options",
            "type": "object",
            "description": "Input POD5 sheet, reference genome, and basecalling model",
            "properties": {
                "pod5_sheet": {
                    "type": "string",
                    "format": "file-path",
                    "description": "Path to TSV file with sample_id and path columns listing POD5 directories per sample.",
                    "fa_icon": "fas fa-table"
                },
                "reference_genome": {
                    "type": "string",
                    "format": "file-path",
                    "description": "Path to reference genome FASTA file for alignment.",
                    "fa_icon": "fas fa-dna"
                },
                "basecall_model": {
                    "type": "string",
                    "description": "Dorado basecalling model name.",
                    "fa_icon": "fas fa-brain",
                    "enum": [
                        "dna_r10.4.1_e8.2_400bps_sup@v4.2.0",
                        "dna_r10.4.1_e8.2_400bps_sup@v4.3.0",
                        "dna_r10.4.1_e8.2_400bps_sup@v5.0.0",
                        "dna_r10.4.1_e8.2_400bps_sup@v5.2.0",
                        "dna_r10.4.1_e8.2_400bps_sup@v4.2.0_5mCG_5hmCG@v2",
                        "dna_r10.4.1_e8.2_400bps_sup@v4.2.0_5mCG_5hmCG@v3.1",
                        "dna_r10.4.1_e8.2_400bps_sup@v4.2.0_5mC@v2",
                        "dna_r10.4.1_e8.2_400bps_sup@v4.2.0_6mA@v2",
                        "dna_r10.4.1_e8.2_400bps_sup@v4.2.0_6mA@v3",
                        "dna_r10.4.1_e8.2_400bps_sup@v4.2.0_5mC_5hmC@v1",
                        "dna_r10.4.1_e8.2_400bps_sup@v4.3.0_5mC_5hmC@v1",
                        "dna_r10.4.1_e8.2_400bps_sup@v4.3.0_6mA@v1",
                        "dna_r10.4.1_e8.2_400bps_sup@v4.3.0_6mA@v2",
                        "dna_r10.4.1_e8.2_400bps_sup@v4.3.0_5mCG_5hmCG@v1",
                        "dna_r10.4.1_e8.2_400bps_sup@v5.0.0_4mC_5mC@v1",
                        "dna_r10.4.1_e8.2_400bps_sup@v5.0.0_4mC_5mC@v2",
                        "dna_r10.4.1_e8.2_400bps_sup@v5.0.0_4mC_5mC@v3",
                        "dna_r10.4.1_e8.2_400bps_sup@v5.0.0_5mC_5hmC@v1",
                        "dna_r10.4.1_e8.2_400bps_sup@v5.0.0_5mC_5hmC@v2.0.1",
                        "dna_r10.4.1_e8.2_400bps_sup@v5.0.0_5mC_5hmC@v3",
                        "dna_r10.4.1_e8.2_400bps_sup@v5.0.0_5mCG_5hmCG@v1",
                        "dna_r10.4.1_e8.2_400bps_sup@v5.0.0_5mCG_5hmCG@v2.0.1",
                        "dna_r10.4.1_e8.2_400bps_sup@v5.0.0_5mCG_5hmCG@v3",
                        "dna_r10.4.1_e8.2_400bps_sup@v5.0.0_6mA@v1",
                        "dna_r10.4.1_e8.2_400bps_sup@v5.0.0_6mA@v2",
                        "dna_r10.4.1_e8.2_400bps_sup@v5.0.0_6mA@v3",
                        "dna_r10.4.1_e8.2_400bps_sup@v5.2.0_4mC_5mC@v1",
                        "dna_r10.4.1_e8.2_400bps_sup@v5.2.0_5mC_5hmC@v1",
                        "dna_r10.4.1_e8.2_400bps_sup@v5.2.0_5mCG_5hmCG@v1",
                        "dna_r10.4.1_e8.2_400bps_sup@v5.2.0_6mA@v1"
                    ]
                },
                "dna": {
                    "type": "boolean",
                    "default": false,
                    "description": "DNA sequencing mode — use map-ont minimap2 preset. Mutually exclusive with --cdna.",
                    "fa_icon": "fas fa-dna"
                },
                "cdna": {
                    "type": "boolean",
                    "default": false,
                    "description": "cDNA sequencing mode — use splice:hq minimap2 preset. Mutually exclusive with --dna.",
                    "fa_icon": "fas fa-flask"
                }
            },
            "required": ["pod5_sheet", "reference_genome", "basecall_model"]
        },
        "output_options": {
            "title": "Output Options",
            "type": "object",
            "description": "Output directory and publishing controls",
            "properties": {
                "output_dir": {
                    "type": "string",
                    "default": "output",
                    "description": "Directory for pipeline output files.",
                    "fa_icon": "fas fa-folder-open"
                },
                "publish_merged_bams": {
                    "type": "boolean",
                    "default": true,
                    "description": "Save merged BAM files after basecalling.",
                    "fa_icon": "fas fa-save"
                },
                "publish_fastq": {
                    "type": "boolean",
                    "default": true,
                    "description": "Save FASTQ files converted from merged BAMs.",
                    "fa_icon": "fas fa-save"
                }
            }
        }
    },
    "allOf": [
        { "$ref": "#/defs/input_options" },
        { "$ref": "#/defs/output_options" },
        {
            "oneOf": [
                {
                    "properties": {
                        "dna": { "const": true },
                        "cdna": { "const": false }
                    }
                },
                {
                    "properties": {
                        "dna": { "const": false },
                        "cdna": { "const": true }
                    }
                }
            ],
            "errorMessage": "Exactly one of --dna or --cdna must be specified"
        }
    ]
}
